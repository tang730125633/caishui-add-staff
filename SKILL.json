{
  "name": "caishui-add-staff",
  "version": "1.0.0",
  "description": "财税通系统自动批量添加员工 - 支持Excel/CSV导入",
  "author": "Claude Code",
  "license": "MIT",
  "keywords": ["财税通", "员工管理", "批量添加", "自动化", "playwright"],
  "homepage": "https://github.com/yourusername/caishui-add-staff",
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/caishui-add-staff.git"
  },
  "engines": {
    "python": ">=3.8"
  },
  "dependencies": {
    "playwright": ">=1.40.0",
    "pandas": ">=2.0.0",
    "openpyxl": ">=3.1.0"
  },
  "scripts": {
    "add-staff": "python caishui_add_staff.py"
  },
  "config": {
    "debugPort": "9222",
    "baseUrl": "https://cst.uf-tree.com",
    "defaultTimeout": 10000
  },
  "capabilities": [
    {
      "name": "add-from-excel",
      "description": "从Excel文件批量添加员工",
      "input": {
        "file": {
          "type": "string",
          "description": "Excel文件路径",
          "required": true
        }
      }
    },
    {
      "name": "add-single",
      "description": "添加单个员工",
      "input": {
        "name": {
          "type": "string",
          "description": "员工姓名",
          "required": true
        },
        "phone": {
          "type": "string",
          "description": "手机号（11位）",
          "required": true
        },
        "department": {
          "type": "string",
          "description": "所属部门/门店",
          "required": true
        }
      }
    }
  ],
  "examples": [
    {
      "description": "从Excel批量添加员工",
      "command": "@caishui-add-staff /Users/tang/Desktop/employees.xlsx"
    },
    {
      "description": "添加单个员工",
      "command": "@caishui-add-staff 张三 13800138000 测试门店1"
    }
  ]
}
